# --- HARDVER ÉS TENSORFLOW BEÁLLÍTÁSOK ---

# 0: Első GPU használata
# -1: GPU letiltása, szigorú CPU használat (azoknak, akiknek nincs GPU-ja)
CUDA_VISIBLE_DEVICES=0

# Memóriakezelés: Ha "true", a TF nem foglalja le a teljes GPU memóriát azonnal, 
# csak amennyire épp szüksége van (nagyon hasznos lokális gépnél).
TF_FORCE_GPU_ALLOW_GROWTH=true

# Logolási szint: 0=Minden, 1=Nincs INFO, 2=Nincs INFO/WARNING, 3=Csak ERROR
# Ha valakinek nincs GPU-ja, a TF rengeteg piros figyelmeztetést dob, ezt a "2" elnémítja.
TF_CPP_MIN_LOG_LEVEL=2


# --- ELÉRÉSI ÚTVONALAK (Környezet-függő) ---

# Ha valaki Colab-ot használ, ez lehet "/content/drive/MyDrive/ood_data"
# Ha lokális, akkor szimplán "./data"
DATA_DIR=./data
MODEL_SAVE_DIR=./saved_models
RESULTS_DIR=./results


# --- KÍSÉRLETI HIPERPARAMÉTEREK (Opcionális felülírás) ---
# Ezeket általában a config.py-ban tartjuk, de ha valakinek a CPU-ja
# nem bírja a 64-es batch méretet, itt lokálisan leveheti 32-re.
BATCH_SIZE=64